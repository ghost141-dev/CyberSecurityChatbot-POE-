<Window x:Class="CybersecurityChatbotWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cybersecurity Awareness Bot"
        Width="960" Height="700"
        MinWidth="800" MinHeight="580"
        Background="#F0F4F8"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    <Grid>

        <!-- HOME GRID -->
        <Grid x:Name="home_grid" Visibility="Visible" Background="#F0F4F8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
                <Image Source="/logo.png" Width="200" Height="160" Margin="0,0,0,24"/>
                <TextBlock
                    Text="Cybersecurity Awareness Bot"
                    FontSize="22" FontWeight="Bold"
                    Foreground="#1E3A5F"
                    TextAlignment="Center"
                    Margin="0,0,0,10"/>
                <TextBlock
                    Text="Your personal guide to staying safe online."
                    FontSize="14" Foreground="#6B7280"
                    TextAlignment="Center"
                    Margin="0,0,0,30"/>
                <Button Content="Get Started"
                        Height="52" FontSize="16" FontWeight="SemiBold"
                        Background="#2563EB" Foreground="White"
                        BorderThickness="0" Cursor="Hand"
                        Click="proceed">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>

        <!-- USERNAME GRID -->
        <Grid x:Name="username_grid" Visibility="Hidden" Background="#F0F4F8">
            <Border Width="460" Height="400"
                    Background="White" CornerRadius="20"
                    Padding="36"
                    VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <Image Source="logo.png" Width="140" Height="110" Margin="0,0,0,18"/>
                    <TextBlock Text="What should I call you?"
                               FontSize="24" FontWeight="Bold"
                               Foreground="#111827"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,20"/>
                    <TextBox x:Name="usernames_input"
                             Height="50" FontSize="16" Padding="12"
                             BorderBrush="#D1D5DB" BorderThickness="2"
                             Background="#F9FAFB"
                             Margin="0,0,0,20"
                             KeyDown="username_input_KeyDown"/>
                    <Button Content="Start Chat"
                            Height="50" FontSize="16" FontWeight="SemiBold"
                            Background="#10B981" Foreground="White"
                            BorderThickness="0" Cursor="Hand"
                            Click="submit_name">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="14">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </Grid>

        <!-- CHAT GRID -->
        <Grid x:Name="chat_grid" Visibility="Hidden">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="210"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT SIDEBAR -->
            <Border Grid.Column="0" Background="#1E3A5F" Padding="12">
                <StackPanel>

                    <!-- ===========================================
                         PART 3 NAVIGATION
                         Switches the right-hand content area between
                         Chat, Task Assistant, Quiz, and Activity Log.
                         Only one panel grid is Visible at a time —
                         same Visibility-toggle pattern as the three
                         top-level screens (home/username/chat).
                    ============================================ -->
                    <TextBlock Text="Cyber Bot" Foreground="White"
                               FontSize="15" FontWeight="Bold"
                               Margin="0,4,0,14"/>

                    <Button x:Name="nav_chat_button" Content="💬 Chat" Tag="chat"
                            Click="nav_button_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="nav_tasks_button" Content="✅ Tasks" Tag="tasks"
                            Click="nav_button_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="nav_quiz_button" Content="🧠 Quiz" Tag="quiz"
                            Click="nav_button_Click" Style="{StaticResource NavButtonStyle}"/>
                    <Button x:Name="nav_log_button" Content="📜 Activity Log" Tag="log"
                            Click="nav_button_Click" Style="{StaticResource NavButtonStyle}"/>

                    <Separator Margin="0,14,0,14" Background="#2D5A8E"/>

                    <TextBlock Text="Topics" Foreground="White"
                               FontSize="13" FontWeight="Bold"
                               Margin="0,0,0,12"/>

                    <!-- Topic Buttons -->
                    <Button Content="🔑 Password"   Tag="password" Click="topic_button_Click" Style="{StaticResource TopicButtonStyle}"/>
                    <Button Content="🎣 Phishing"   Tag="phishing" Click="topic_button_Click" Style="{StaticResource TopicButtonStyle}"/>
                    <Button Content="🌐 Browsing"   Tag="browsing" Click="topic_button_Click" Style="{StaticResource TopicButtonStyle}"/>
                    <Button Content="🔒 Privacy"    Tag="privacy"  Click="topic_button_Click" Style="{StaticResource TopicButtonStyle}"/>
                    <Button Content="🐛 Malware"    Tag="malware"  Click="topic_button_Click" Style="{StaticResource TopicButtonStyle}"/>
                    <Button Content="⚠️ Social Eng" Tag="social"   Click="topic_button_Click" Style="{StaticResource TopicButtonStyle}"/>
                    <Button Content="🔐 2FA"        Tag="2fa"      Click="topic_button_Click" Style="{StaticResource TopicButtonStyle}"/>
                    <Button Content="🛡️ Scams"      Tag="scam"     Click="topic_button_Click" Style="{StaticResource TopicButtonStyle}"/>
                    <Button Content="🔗 Links"      Tag="links"    Click="topic_button_Click" Style="{StaticResource TopicButtonStyle}"/>
                    <Button Content="📱 Mobile"     Tag="mobile"   Click="topic_button_Click" Style="{StaticResource TopicButtonStyle}"/>

                    <Separator Margin="0,16,0,12" Background="#2D5A8E"/>

                    <!-- Memory Panel -->
                    <TextBlock Text="Memory" Foreground="White"
                               FontSize="13" FontWeight="Bold"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="memory_panel"
                               Foreground="#A0C4E8"
                               FontSize="11"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- CHAT AREA -->
            <Grid x:Name="chat_panel_grid" Grid.Column="1" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="70"/>
                </Grid.RowDefinitions>

                <!-- Messages -->
                <ListView x:Name="chats"
                          Grid.Row="0"
                          Background="#F0F4F8"
                          BorderThickness="0"
                          Padding="12,8,12,8"
                          ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListViewItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <!-- Input Bar -->
                <Border Grid.Row="1" Background="White"
                        BorderBrush="#D1D5DB" BorderThickness="0,1,0,0"
                        Padding="12,10,12,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="question"
                                 Grid.Column="0"
                                 Height="44" FontSize="14" Padding="12,10"
                                 BorderBrush="#D1D5DB" BorderThickness="1"
                                 Background="#F9FAFB"
                                 VerticalContentAlignment="Center"
                                 Margin="0,0,10,0"
                                 KeyDown="question_KeyDown"/>
                        <Button Content="Send"
                                Grid.Column="1"
                                Height="44" FontSize="14" FontWeight="SemiBold"
                                Background="#2563EB" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="send">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="10">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                </Border>
            </Grid>

            <!-- ===================================================
                 TASK ASSISTANT PANEL (Part 3, Task 1)
                 Add/view/complete/delete cybersecurity tasks, backed
                 by MySQL via TaskAssistantHandler. Hidden by default;
                 shown when "Tasks" is clicked in the sidebar nav.
            ==================================================== -->
            <Grid x:Name="tasks_panel_grid" Grid.Column="1" Visibility="Hidden" Background="#F0F4F8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <StackPanel Grid.Row="0" Margin="20,18,20,4">
                    <TextBlock Text="Cybersecurity Task Assistant"
                               FontSize="20" FontWeight="Bold" Foreground="#1E3A5F"/>
                    <TextBlock x:Name="tasks_db_status_text"
                               Text="" FontSize="12" Foreground="#B91C1C"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Add-task form -->
                <Border Grid.Row="1" Background="White" CornerRadius="14"
                        Margin="20,12,20,12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Add a new task" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#111827" Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="160"/>
                                <ColumnDefinition Width="110"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="new_task_title_input" Grid.Column="0"
                                     Height="40" Padding="10,8" FontSize="13"
                                     BorderBrush="#D1D5DB" BorderThickness="1"
                                     Background="#F9FAFB" Margin="0,0,8,0"
                                     VerticalContentAlignment="Center"
                                     ToolTip="e.g. Enable two-factor authentication"/>
                            <ComboBox x:Name="new_task_reminder_combo" Grid.Column="1"
                                      Height="40" FontSize="13" Margin="0,0,8,0"
                                      VerticalContentAlignment="Center"
                                      SelectedIndex="0">
                                <ComboBoxItem Content="No reminder"/>
                                <ComboBoxItem Content="Remind in 1 day"/>
                                <ComboBoxItem Content="Remind in 3 days"/>
                                <ComboBoxItem Content="Remind in 7 days"/>
                            </ComboBox>
                            <Button Grid.Column="2" Content="Add Task"
                                    Style="{StaticResource PrimaryActionButtonStyle}"
                                    Click="add_task_button_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Task list -->
                <Border Grid.Row="2" Background="White" CornerRadius="14"
                        Margin="20,0,20,20" Padding="8">
                    <ListView x:Name="tasks_list_view" BorderThickness="0"
                              Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Border>
            </Grid>

            <!-- ===================================================
                 QUIZ PANEL (Part 3, Task 2)
                 One question at a time, immediate feedback, running
                 score. Backed by QuizEngine. Hidden by default.
            ==================================================== -->
            <Grid x:Name="quiz_panel_grid" Grid.Column="1" Visibility="Hidden" Background="#F0F4F8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Cybersecurity Knowledge Quiz"
                           FontSize="20" FontWeight="Bold" Foreground="#1E3A5F"
                           Margin="20,18,20,12"/>

                <!-- Start screen -->
                <StackPanel x:Name="quiz_start_panel" Grid.Row="1"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="Visible">
                    <TextBlock Text="🛡️" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="Test your cybersecurity knowledge!" FontSize="16"
                               Foreground="#374151" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                    <Button Content="Start Quiz" Width="200"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Click="start_quiz_button_Click"/>
                </StackPanel>

                <!-- Active question screen -->
                <Border x:Name="quiz_question_panel" Grid.Row="1"
                        Background="White" CornerRadius="14"
                        Margin="20,0,20,20" Padding="24"
                        VerticalAlignment="Top" Visibility="Hidden">
                    <StackPanel>
                        <TextBlock x:Name="quiz_progress_text" Text="Question 1 of 12"
                                   FontSize="12" Foreground="#6B7280" Margin="0,0,0,8"/>
                        <TextBlock x:Name="quiz_question_text" Text=""
                                   FontSize="16" FontWeight="SemiBold" Foreground="#111827"
                                   TextWrapping="Wrap" Margin="0,0,0,16"/>
                        <StackPanel x:Name="quiz_options_panel"/>
                        <TextBlock x:Name="quiz_feedback_text" Text=""
                                   FontSize="13" TextWrapping="Wrap"
                                   Margin="0,16,0,12" Visibility="Collapsed"/>
                        <Button x:Name="quiz_next_button" Content="Next Question"
                                Width="160" HorizontalAlignment="Left"
                                Style="{StaticResource PrimaryActionButtonStyle}"
                                Click="quiz_next_button_Click" Visibility="Collapsed"/>
                    </StackPanel>
                </Border>

                <!-- Results screen -->
                <StackPanel x:Name="quiz_results_panel" Grid.Row="1"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Visibility="Hidden">
                    <TextBlock x:Name="quiz_score_text" Text="" FontSize="20" FontWeight="Bold"
                               Foreground="#1E3A5F" HorizontalAlignment="Center"
                               TextWrapping="Wrap" TextAlignment="Center" MaxWidth="420"
                               Margin="0,0,0,20"/>
                    <Button Content="Play Again" Width="200"
                            Style="{StaticResource PrimaryActionButtonStyle}"
                            Click="start_quiz_button_Click"/>
                </StackPanel>
            </Grid>

            <!-- ===================================================
                 ACTIVITY LOG PANEL (Part 3, Task 4)
                 Shows the most recent 8 actions with a "Show more"
                 option. Backed by ActivityLogger. Hidden by default.
            ==================================================== -->
            <Grid x:Name="log_panel_grid" Grid.Column="1" Visibility="Hidden" Background="#F0F4F8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Activity Log"
                           FontSize="20" FontWeight="Bold" Foreground="#1E3A5F"
                           Margin="20,18,20,12"/>

                <Border Grid.Row="1" Background="White" CornerRadius="14"
                        Margin="20,0,20,12" Padding="8">
                    <ListView x:Name="log_list_view" BorderThickness="0"
                              Background="Transparent"
                              ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListViewItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Border>

                <Button x:Name="log_show_more_button" Grid.Row="2" Content="Show Full History"
                        Width="200" HorizontalAlignment="Left" Margin="20,0,20,20"
                        Style="{StaticResource PrimaryActionButtonStyle}"
                        Click="log_show_more_button_Click"/>
            </Grid>
        </Grid>
    </Grid>
</Window>